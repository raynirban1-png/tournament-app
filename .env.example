# Copy this file to .env for local development and fill in real values.
# In production (GitHub Actions), these are pulled from repo Secrets/Variables instead — see README.

# Supabase project settings (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Payment QR settings
VITE_UPI_ID=yourname@upi
VITE_UPI_PAYEE_NAME=Tournament Committee

# General tournament settings
VITE_TOURNAMENT_NAME=City Football Cup 2026
VITE_REGISTRATION_FEE=2000
